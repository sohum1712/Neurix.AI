# ===========================================
# ZEO.AI SERVER ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3001
NODE_ENV=production

# Tavus AI Configuration (Get from https://tavus.io)
TAVUS_API_KEY=your_tavus_api_key_here
TAVUS_API_URL=https://tavusapi.com/v2
TAVUS_REPLICA_ID=your_replica_id_here
# TAVUS_DEFAULT_PERSONA_ID=your_persona_id

# Google Gemini AI Configuration (Get from https://ai.google.dev)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_VERSION=v1beta
GEMINI_MODEL=gemini-2.5-flash

# MongoDB Configuration
MONGODB_URI=your_mongodb_connection_string

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info

# Security (Generate strong secret for production)
# SESSION_SECRET=your_session_secret_here

# HIPAA Compliance - Encryption Key (REQUIRED for production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_character_hex_encryption_key_here

# Data Retention (HIPAA compliance - days to retain data)
DATA_RETENTION_DAYS=30
