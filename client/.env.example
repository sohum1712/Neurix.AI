# ===========================================
# ZEO.AI CLIENT ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your values

# API Configuration
VITE_API_BASE_URL=http://localhost:3001/api

# Tavus AI Configuration (Get from https://tavus.io)
VITE_TAVUS_API_KEY=your_tavus_api_key_here
VITE_TAVUS_API_URL=https://tavusapi.com/v2
VITE_TAVUS_REPLICA_ID=your_replica_id_here
# VITE_TAVUS_DEFAULT_PERSONA_ID=your_persona_id

# Supabase Configuration (Get from https://supabase.com)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Feature Flags
VITE_ENABLE_TAVUS=true
VITE_ENABLE_AUTH=true

# App Configuration
VITE_APP_URL=http://localhost:8081
VITE_DEV_MODE=false
